# Banco de dados (PostgreSQL no VPS)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/rcontrol?schema=public"

# NextAuth
NEXTAUTH_URL="https://rcontrol.rigueto.com.br"
NEXTAUTH_SECRET="gerar com: openssl rand -base64 32"

# Groq AI (free tier em console.groq.com)
GROQ_API_KEY="gsk_..."

# Evolution API (WhatsApp - já instalado no VPS)
EVOLUTION_API_URL="http://evolution-api:8080"
EVOLUTION_API_KEY="sua-chave-evolution"
EVOLUTION_INSTANCE="r-control"

# Segurança do webhook
WHATSAPP_WEBHOOK_SECRET="gerar com: openssl rand -hex 32"
